# Copie ce fichier en .streamlit/secrets.toml et remplace la valeur.
# .streamlit/secrets.toml est ignoré par git (voir .gitignore).
#
# Sur Streamlit Community Cloud, configure plutôt les Secrets dans
# Settings → Secrets de l'application déployée — ne pousse JAMAIS
# de vraie clé sur GitHub.

ANTHROPIC_API_KEY = "sk-ant-..."
