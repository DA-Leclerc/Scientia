# Variables d'environnement requises pour Scientia
# Copier ce fichier en .env pour développement local :
#     cp .env.example .env
# puis remplacer la valeur ci-dessous par TA clé.
# Le fichier .env est ignoré par git (voir .gitignore).
# NE JAMAIS coller une vraie clé dans .env.example.

# Clé API Anthropic (obligatoire)
# Génère-la sur https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...

# Clé API OpenAI (optionnelle — uniquement pour le mode vocal teach-back)
# Génère-la sur https://platform.openai.com/api-keys
# Sans cette clé, le teach-back fonctionne en mode texte uniquement.
# OPENAI_API_KEY=sk-proj-...

# Chemin vers la voûte Obsidian (optionnel — pour la fonction sync)
# Si défini, les concepts maîtrisés peuvent être synchronisés vers
# {OBSIDIAN_VAULT_PATH}/governance-frameworks/wiki/concepts/scientia-mastered/
# OBSIDIAN_VAULT_PATH=C:\Users\subur\Desktop\NordParadigm-KB

# Dossier de données persistantes (Railway uniquement)
# En local : laisser commenté (utilise le dossier courant).
# Sur Railway : définir DATA_DIR=/data + monter un volume sur /data.
# DATA_DIR=/data
